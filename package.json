{
  "name": "@turbo-agent/daisyui-prompt-kit",
  "version": "0.1.3",
  "description": "A DaisyUI-based React component library for AI chat interfaces",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/turbo-agent/daisyui-prompt-kit.git"
  },
  "homepage": "https://github.com/turbo-agent/daisyui-prompt-kit#readme",
  "bugs": {
    "url": "https://github.com/turbo-agent/daisyui-prompt-kit/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./styles": "./dist/styles.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode lib",
    "build:demo": "cd demo && vite build",
    "build:lib": "vite build --mode lib",
    "preview": "vite preview",
    "demo": "cd demo && vite --port 3005"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "daisyui": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.0",
    "@iconify/tailwind4": "^1.0.0",
    "@iconify-json/lucide": "^1.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "katex": "^0.16.40",
    "marked": "^15.0.7",
    "react-jsx-parser": "^2.4.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^3.0.0",
    "tailwind-merge": "^3.0.1",
    "use-stick-to-bottom": "^1.1.1"
  },
  "devDependencies": {
    "@iconify-json/hugeicons": "^1.2.24",
    "@iconify-json/lucide": "^1.2.98",
    "@iconify-json/material-icon-theme": "^1.2.56",
    "@iconify-json/ri": "^1.2.10",
    "@iconify/tailwind4": "^1.2.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "daisyui": "^5.5.14",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.1.18",
    "typescript": "~5.7.2",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.0"
  },
  "keywords": [
    "react",
    "daisyui",
    "tailwindcss",
    "ai",
    "chat",
    "components",
    "prompt-kit"
  ],
  "license": "MIT"
}
